{
  "title": "CSIP Overview",
  "uid": "csip-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "tags": ["csip", "serving", "drift"],
  "panels": [
    {
      "id": 1,
      "title": "Prediction Throughput",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (task) (rate(csip_predictions_total[1m]))",
          "legendFormat": "{{task}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Prediction Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, task) (rate(csip_prediction_latency_seconds_bucket[5m])))",
          "legendFormat": "p50 {{task}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, task) (rate(csip_prediction_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{task}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, task) (rate(csip_prediction_latency_seconds_bucket[5m])))",
          "legendFormat": "p99 {{task}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "Prediction Error Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (task) (rate(csip_prediction_errors_total[5m])) / sum by (task) (rate(csip_predictions_total[5m]))",
          "legendFormat": "{{task}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Confidence Distribution",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (le, task) (rate(csip_prediction_confidence_bucket[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Models Loaded",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "csip_models_loaded",
          "legendFormat": "models loaded",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Feature Drift PSI",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 0.25 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "csip_feature_drift_psi",
          "legendFormat": "{{feature}}",
          "refId": "A"
        }
      ]
    }
  ]
}
