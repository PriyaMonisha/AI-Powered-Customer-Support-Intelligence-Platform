# Copy this file to .env and fill in real values
# .env is gitignored — NEVER commit the real .env

# PostgreSQL
# Host port 5433 (not 5432) — avoids clashing with a local native PostgreSQL install
DB_URL=postgresql+psycopg2://postgres:YOUR_PG_PASSWORD@localhost:5433/csip

# Redis
REDIS_URL=redis://localhost:6379

# MLflow
MLFLOW_URI=http://localhost:5001

# HuggingFace Hub (get from https://huggingface.co/settings/tokens)
HF_HUB_TOKEN=hf_YOUR_TOKEN_HERE
HF_USERNAME=your_huggingface_username

# FastAPI admin key (for /admin/reload endpoint — keep separate from public API key)
ADMIN_API_KEY=choose_a_strong_random_string_here

# FastAPI public key (for /predict endpoints)
API_KEY=choose_another_strong_random_string_here

# Airflow DAG alert webhook (Slack-compatible). Independent of Prometheus/Alertmanager.
CSIP_ALERT_WEBHOOK=

# Section 14 — Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_MULTIPLE_DATABASES=airflow

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

AIRFLOW_UID=50000
# Generated automatically by scripts/generate_env.py
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
