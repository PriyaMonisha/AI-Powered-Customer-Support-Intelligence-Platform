# Virtual environment
venv/
.venv/
env/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pdb

# Jupyter notebooks (use .py with # %% markers instead)
*.ipynb
.ipynb_checkpoints/

# Environment secrets — NEVER commit
.env
*.env.local

# Data — raw data stays local, never in git
/data/raw/
/data/processed/

# ML artifacts — large files
mlruns/
/models/
/artifacts/charts/
/artifacts/drift/
/artifacts/tmp/
/artifacts/reports/drift_report_*.html
*.pkl
*.pt
*.h5
*.onnx

# MLflow DB
mlflow.db

# GloVe embeddings (large)
glove.*.txt
glove.*.zip

# Logs
*.log
logs/

# Dev tool memory and config — not for public repo
.claude/
CLAUDE.md
INTERVIEW_PREP_*.md

# Course material PDFs — not project code
*.pdf
*.docx

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Docker
.docker/

